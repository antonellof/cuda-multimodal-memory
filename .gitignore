# ‚îÄ‚îÄ‚îÄ LaTeX intermediates (paper/) ‚îÄ‚îÄ‚îÄ
# Keep main.tex, references.bib, figures/, and main.pdf; drop everything else.
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.log
paper/*.out
paper/*.toc
paper/*.synctex.gz
paper/*.fdb_latexmk
paper/*.fls

# ‚îÄ‚îÄ‚îÄ Python ‚îÄ‚îÄ‚îÄ
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/

# ‚îÄ‚îÄ‚îÄ Editor / IDE ‚îÄ‚îÄ‚îÄ
